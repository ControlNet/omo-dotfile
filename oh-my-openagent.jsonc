      "variant": "medium"
    },
    "prometheus": {
      "model": "codex/gpt-5.5",
      "variant": "high"
    },
    "metis": {
      "model": "codex/gpt-5.5",
      "variant": "high"
    },
    "momus": {
      "model": "codex/gpt-5.5",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "codex/gpt-5.4",
      "variant": "medium"
    },
    "sisyphus-junior": {
      "model": "codex/gpt-5.4",
      "variant": "high"
    }
