  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false
  },
  "background_task": {
    "maxDescendants": 300
  },
  "claude_code": {
    "skills": false,
    "commands": false,
    "mcp": false,
    "agents": false,
    "hooks": false,
    "plugins": false
