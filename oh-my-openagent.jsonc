  "categories": {
    "visual-engineering": {
      "model": "codex/gpt-5.4",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "codex/gpt-5.4",
      "variant": "xhigh"
    },
    "deep": {
      "model": "codex/gpt-5.4",
      "variant": "high"
    },
    "artistry": {
      "model": "codex/gpt-5.4",
      "variant": "high"
    },
    "quick": {
